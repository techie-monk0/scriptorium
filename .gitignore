# The catalogue DB lives under the tracked private/ tree (stripped from the public
# release). ONLY the live catalogue.db is version-controlled — as a raw blob on the
# private main branch. Everything else in the dir stays local: WAL sidecars, the
# backups/ + timestamped *.bak / backup-*.db / *.pre-*.db snapshots, and the
# .cover-cache / .webdav-cache / covers-pinned / isbn_backfill_*.json sidecars.
/private/catalogue-db/*
!/private/catalogue-db/catalogue.db
# Any legacy top-level catalogue-db/ (pre-move) stays ignored too.
/catalogue-db/
*.db-shm
*.db-wal
*.bak

# Step-4 staging scratch — artifacts are replayed into the DB by run_load, then
# disposable (and move themselves to <dir>/loaded/).
/staging/
/staging_*/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Timestamped local DB backups + pre-write consistency snapshots — kept locally,
# NEVER in git (each is ~500MB+). The private/catalogue-db/* rule above already
# ignores those under the data dir; these globals catch them anywhere.
# The full pre-2026-06-11 git history lives in ~/Dev-backup/library_cataloging-history.git.
*.bak-*
*-backup-*.db
*.backup-*.db

# OCR scratch (never in git)
ocr_review/

# Phantom DBs created when an open connection (or a non-path) was passed where a
# path was expected — connect() now rejects that, but ignore any historical ones.
# (Delete on disk; they hold no real data.)
*sqlite3.Connection object*
catalogue/db.sqlite

# Run logs / regenerable analysis dumps
*.log

# Files parked for deletion (REMOVE_ prefix convention)
REMOVE_*

# Secrets live in private/secrets/ (their home). private/ is otherwise tracked, so
# ignore the whole secrets dir explicitly — nothing under it is ever committed.
/private/secrets/
# Belt-and-suspenders: also ignore these by name wherever they appear.
api_key.txt
.kdrive_settings
*.key
.env

# Scratch / scan artifacts
*.tmp

# Editor / OS / agent cruft
.DS_Store
.claude/

# Empty placeholder DB at repo root (real one is private/catalogue-db/catalogue.db)
/catalogue.db

# MyScript SDK certificate — a licensed commercial credential, kept local, never
# committed. Unanchored so it's ignored wherever it sits in the tree.
MyScript_ios_certificate.c
