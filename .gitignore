# catalogue-db/ is RUNTIME USER DATA, never committed. It holds the user-supplied
# catalogue.db (the personal library), its WAL sidecars, local backups, cover
# caches, and pinned covers. The code resolves the DB location via db_store's
# default_db_path() ($CATALOGUE_DB → $CATALOGUE_DATA_DIR → ./catalogue-db/), so the
# data can live anywhere; this repo ships no database. Back the DB up yourself
# (git history is NOT its backup anymore).
/catalogue-db/
*.db-shm
*.db-wal
*.bak

# Step-4 staging scratch — artifacts are replayed into the DB by run_load, then
# disposable (and move themselves to <dir>/loaded/).
/staging/
/staging_*/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Timestamped local DB backups (the tracked catalogue-db/catalogue.db is canonical)
*.bak-*
catalogue-db/*.bak-*
*-backup-*.db
catalogue-db/*-backup-*.db
*.backup-*.db
catalogue-db/*.backup-*.db

# Timestamped consistency snapshots taken before bulk/destructive writes. These
# are on-disk DB backups kept locally, NOT in git (each is ~500MB+). The full
# pre-2026-06-11 git history lives in ~/Dev-backup/library_cataloging-history.git.
catalogue-db/catalogue.snapshot-*.db
catalogue-db/catalogue.pre-*.db

# Local caches + one-off backfill outputs + OCR scratch (never in git)
catalogue-db/.cover-cache/
catalogue-db/.webdav-cache/
catalogue-db/isbn_backfill_*.json
ocr_review/

# Phantom DBs created when an open connection (or a non-path) was passed where a
# path was expected — connect() now rejects that, but ignore any historical ones.
# (Delete on disk; they hold no real data.)
*sqlite3.Connection object*
catalogue/db.sqlite

# Run logs / regenerable analysis dumps
*.log

# Files parked for deletion (REMOVE_ prefix convention)
REMOVE_*

# Secrets — never commit (API keys live here or in env vars)
api_key.txt
*.key
.env

# Scratch / scan artifacts
*.tmp

# Editor / OS / agent cruft
.DS_Store
.claude/

# Empty placeholder DB at repo root (real one is catalogue-db/catalogue.db)
/catalogue.db

# Large external archive dir + session scratch
/archival/
/16_books.md
/OxfordTantric-Glossary.pdf
/force_ocr_prasannapada.py
/_test_summary.txt

# Local WebDAV / kDrive credentials (never commit)
.kdrive_settings
catalogue-db/*.bak

# MyScript SDK certificate — a licensed commercial credential, kept local, never
# committed. Unanchored so it's ignored wherever it sits in the tree.
MyScript_ios_certificate.c
